# ClawShow MCP Server — environment variables
# Copy to .env for local development (never commit .env)

# Port for SSE server (Railway sets this automatically)
PORT=8000

# Optional: override bind host
HOST=0.0.0.0

# GitHub — required for generate_rental_website
GITHUB_TOKEN=ghp_xxx

# Stripe — required for generate_stripe_payment + webhook
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend — required for send_notification
RESEND_API_KEY=re_xxx
